APP_NAME=ARCA CONTINENTAL Energy API
API_V1_PREFIX=/api/v1
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_MODE=demo

# Used only when DB_MODE=demo
DATABASE_URL=sqlite:///./energy_dashboard.db

# SQL Server connection
SQLSERVER_HOST=(localdb)\MSSQLLocalDB
SQLSERVER_DATABASE=ION_Network
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SQLSERVER_TRUST_CERT=true
SQLSERVER_ENCRYPT=optional
SQLSERVER_USE_WINDOWS_AUTH=true

# Only needed when SQLSERVER_USE_WINDOWS_AUTH=false
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=
SQLSERVER_PORT=1433

# demo -> usa datos semilla locales
# table -> lee desde la vista/tabla de SQL Server
SQLSERVER_SOURCE_MODE=table
SQLSERVER_SOURCE_TABLE=dbo.v_dashboard_measurements

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
